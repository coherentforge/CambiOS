# External repo cloned locally for convenience — canonical source is
# github.com/riccajason/mcp-rust-analyzer, wired in via .mcp.json.
# The local .venv / __pycache__ / server.py belong to that project,
# not this one.
tools/mcp-rust-analyzer/

# Python bytecode cache from tools/*.py runs.
__pycache__/

# Personal scratch notes — drafts, proposals, working memos.
notes/

# Dev-PIV keypair files. Generated per-developer by
# `make gen-dev-piv-keys`; never committed. Production builds use the
# committed bootstrap_pubkey.bin (real YubiKey) instead, selected by
# the absence of `--features dev-piv`.
dev_bootstrap_pubkey.bin
dev_slot_9c_seed.bin
user/key-store-service/dev_piv_secret.bin
tools/gen-dev-piv-keys/.dev-seed.bin
