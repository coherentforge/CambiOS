/target
user/*/target/
tools/*/target/
verification/*/target/
fuzz/target/
cambios-abi/target/
cambios-manifest/target/
cambios-fde-proto/target/
cambios-ccid-proto/target/
fuzz/artifacts/
fuzz/corpus/
*.iso
*.img
*.elf
*.o
iso_root/
.DS_Store
*.log
.symbols

# External repo cloned locally for convenience — canonical source is
# github.com/riccajason/mcp-rust-analyzer, wired in via .mcp.json.
# The local .venv / __pycache__ / server.py belong to that project,
# not this one.
tools/mcp-rust-analyzer/

# Python bytecode cache from tools/*.py runs.
__pycache__/

# Personal scratch notes — drafts, proposals, working memos.
notes/

# Dev-PIV keypair files. Generated per-developer by
# `make gen-dev-piv-keys`; never committed. Production builds use the
# committed bootstrap_pubkey.bin (real YubiKey) instead, selected by
# the absence of `--features dev-piv`.
dev_bootstrap_pubkey.bin
dev_slot_9c_seed.bin
user/key-store-service/dev_piv_secret.bin
tools/gen-dev-piv-keys/.dev-seed.bin

# Claude Code state. settings.json (shared allowlist for the project's
# own lint/check commands) is committed; settings.local.json
# (per-developer permission grants + the PostToolUse edit-log hook)
# and worktrees/ (session-scoped side checkouts) stay local.
.claude/*
!.claude/settings.json

# Boot manifest blob — build artifact of `make manifest` (ADR-018).
# The source of truth is manifest.toml (committed); the signed blob is
# regenerated per build like the ISOs.
manifest.bin
